# Public base URL of the deployed app (used for share links). Optional in dev.
NEXT_PUBLIC_APP_URL=

# Public support inbox shown on Privacy, Terms, and Support pages.
NEXT_PUBLIC_SUPPORT_EMAIL=

# Download targets shown on /download. Optional — sensible fallbacks are used.
NEXT_PUBLIC_CHROME_WEBSTORE_URL=
NEXT_PUBLIC_MACOS_DOWNLOAD_URL=
NEXT_PUBLIC_EXTENSION_URL=

# Supabase (optional). If these are unset, TabZero falls back to in-memory storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (optional). Priority: OpenAI > Gemini > deterministic mock analyzer.
OPENAI_API_KEY=
GEMINI_API_KEY=
