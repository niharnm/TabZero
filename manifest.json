{
  "manifest_version": 3,
  "name": "BurnoutCheck",
  "version": "1.0.0",
  "description": "Privacy-first burnout detector. Reads tab behavior patterns (never page content) and scores your stress in real time.",
  "permissions": ["tabs", "storage", "alarms", "notifications", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BurnoutCheck"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["reset.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
