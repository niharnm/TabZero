{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TabZero",
  "version": "0.1.0",
  "identifier": "app.tabzero.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TabZero",
        "width": 1180,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
